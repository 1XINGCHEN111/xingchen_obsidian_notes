############################
# Obsidian 同步逻辑优化
############################

# 1. 屏蔽整个文件夹（防止杂碎文件漏网）
.obsidian/

# 2. 强制【允许】同步的核心配置
!.obsidian/plugins/
!.obsidian/themes/
!.obsidian/snippets/
!.obsidian/app.json
!.obsidian/appearance.json
!.obsidian/hotkeys.json
!.obsidian/core-plugins.json
!.obsidian/community-plugins.json

# 3. 坚决【禁止】同步的冲突大户
.obsidian/workspace
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache/
.obsidian/index.db*
.obsidian/graph.json