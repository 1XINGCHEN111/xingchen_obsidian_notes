		},
		{"id":"da2d7b3882b1bd5c","type":"file","file":"日语学习/语法系统梳理/附件/{2FF5BF03-02B6-4583-97B0-843C626A3A71}.png","x":-4340,"y":-460,"width":400,"height":196},
		{"id":"4cf5f2e59fb98bd4","type":"file","file":"日语学习/语法系统梳理/附件/{02FBB603-0E93-4954-B678-1EF51308850C}.png","x":-3680,"y":-657,"width":399,"height":267},
		{
			"id":"db1acf45e9ca06c8",
			"type":"text",
			"text":"みたい只能用在口语，ようだ两者都可以\n两个意思基本一样，用法一样",
			"styleAttributes":{},
			"x":-3670,
			"y":-324,
			"width":380,
			"height":84
		},
		{
			"id":"870ff1b1d9b32c06",
			"type":"text",
			"text":"根据自身的感觉",
			"styleAttributes":{},
			"x":-3820,
			"y":-846,
			"width":260,
			"height":60,
			"color":"3"
		},
		{
			"id":"f336878996b5a933",
			"type":"text",
			"text":"根据眼前的景象",
			"styleAttributes":{},
			"x":-3840,
			"y":-1941,
			"width":260,
			"height":60
		},
		{"id":"0dbd78ad1f4f351d","type":"file","file":"日语学习/语法系统梳理/附件/{1FBE7CDD-2D4D-4E8C-A19A-6719E62E3894}.png","x":-220,"y":-640,"width":119,"height":33},
		{
			"id":"174c0209503d24d9",
			"type":"text",
			"text":"所有的未然形：\n五段动词 あ　お　段，一段删る，\nする　ー　し/せ/さ\nくる　ー　こ\n结尾是あ，一般会变为わ",
			"styleAttributes":{},
			"x":-220,
			"y":-593,
			"width":260,
			"height":186,
			"color":"2"
		},
		{"id":"0d9161cd6aed55ae","type":"file","file":"日语学习/语法系统梳理/附件/{617AAD5B-F9E9-4060-B8AF-64DBD68CAE07}.png","x":-1800,"y":-560,"width":200,"height":74},
		{
			"id":"59d31f3b4d698d17",
			"type":"text",
			"text":"我一定要成功给你看",
