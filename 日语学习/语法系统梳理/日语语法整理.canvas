			"color":"2"
		},
		{"id":"e2e3bb6a40940ad2","type":"file","file":"日语学习/语法系统梳理/附件/{EDAE812C-4117-4FDD-9CBB-D4D9BB103535}.png","x":-4340,"y":-1240,"width":400,"height":394},
		{
			"id":"9bb8ce58e84b56cb",
			"type":"text",
			"text":"要有足够的证据",
