			"width":260,
			"height":60
		},
		{"id":"081af8d9b374a06e","type":"file","file":"日语学习/语法系统梳理/附件/{2D4D21C9-9431-4230-BC4A-84DBFD379790}.png","x":-882,"y":1823,"width":400,"height":56},
		{
			"id":"5adbc202f7c7e18c",
			"type":"text",
			"text":"日语本身形容词过少，用名词作为词干后面加\n上「だ」构成，可以认为是一系列特殊的名词",
			"styleAttributes":{},
			"x":-812,
			"y":1940,
