			"width":260,
			"height":60
		},
		{"id":"c5899f94450dd8f3","type":"file","file":"日语学习/语法系统梳理/附件/{5F36B8E7-A4BE-4A1F-ACE6-6710B624DBB6}.png","x":-1346,"y":1440,"width":296,"height":260},
		{
			"id":"2c1c1c0d5bc7fbc7",
			"type":"text",
			"text":"连体形：词干 + な",
			"styleAttributes":{},
