			"width":260,
			"height":60
		},
		{"id":"f562f8fc38788e34","type":"file","file":"日语学习/语法系统梳理/附件/{4B32EA26-DA17-44F9-A7CF-E2FB34C665B9}.png","x":57,"y":-3977,"width":180,"height":163},
		{"id":"ee5bb764e30370b7","type":"file","file":"日语学习/语法系统梳理/附件/{A73B2FD9-B527-4B08-A395-A2E89A4E8935}.png","x":57,"y":-3800,"width":233,"height":120},
		{"id":"cc635facf29a75f8","type":"file","file":"日语学习/语法系统梳理/附件/{BB9F7389-59D5-4FE2-ADA2-8ABA93501314}.png","x":57,"y":-3650,"width":253,"height":144},
		{
			"id":"d014c25da4532af9",
			"type":"text",
			"text":"并列",
			"styleAttributes":{},
			"x":-692,
			"y":-4150,
			"width":110,
			"height":60
		},
		{
			"id":"db9fefeda5cceac1",
			"type":"text",
			"text":"接续助词",
			"styleAttributes":{},
			"x":-433,
			"y":-4060,
			"width":170,
			"height":60
		},
		{
			"id":"fcf890e153ec854b",
			"type":"text",
			"text":"假定顺接",
			"styleAttributes":{},
			"x":-203,
			"y":-4060,
			"width":160,
			"height":60
		},
		{
			"id":"dd59a507ad4736d5",
			"type":"text",
			"text":"确定顺接",
			"styleAttributes":{},
			"x":-203,
			"y":-3980,
			"width":160,
			"height":60
		},
		{
			"id":"dcd73cbda7f991bc",
			"type":"text",
			"text":"假定形\n多い　ー　多けれ\n静かだ　ー　静かなら\n学生だ　ー　学生なら\n动词所有最后一个字变成え段",
			"styleAttributes":{},
			"x":-518,
			"y":-3896,
			"width":340,
			"height":160,
			"color":"2"
		},
		{
			"id":"535b596e165e6d97",
			"type":"text",
			"text":"形容动词的ば可以省略",
			"styleAttributes":{},
			"x":-478,
			"y":-3680,
			"width":260,
			"height":60
		},
		{"id":"1c37173574429abf","type":"file","file":"日语学习/语法系统梳理/附件/{E81C51E2-8402-4B00-9129-87EC8E4BCC24}.png","x":-123,"y":-3578,"width":60,"height":149},
		{
			"id":"14e62abe2899ed63",
			"type":"text",
			"text":"助词",
			"styleAttributes":{},
			"x":-743,
			"y":-3360,
			"width":120,
			"height":60
		},
		{
			"id":"9a5b948d3f6f6d1a",
			"type":"text",
			"text":"副助词：在格助词后添加含义",
			"styleAttributes":{},
			"x":-563,
			"y":-3360,
			"width":300,
			"height":60
		},
		{"id":"ab7569181c93de6a","type":"file","file":"日语学习/语法系统梳理/附件/现代部分-4 1.pdf","x":-2023,"y":-3589,"width":850,"height":519},
		{
			"id":"af3dae974be5e9a0",
			"type":"text",
			"text":"格助词",
			"styleAttributes":{},
			"x":-1113,
			"y":-3360,
			"width":260,
			"height":60
		},
		{
			"id":"9ee2a0afc3c118eb",
			"type":"text",
			"text":"用把字句区分宾语和对象",
			"styleAttributes":{},
			"x":-1113,
			"y":-3250,
			"width":260,
			"height":60
		},
		{
			"id":"c412ce51aba09dbf",
			"type":"text",
			"text":"把前面的短语转换为修饰名词的形式",
			"styleAttributes":{},
			"x":-2543,
			"y":-3100,
			"width":360,
			"height":60
		},
		{
			"id":"d653b0598c18577d",
			"type":"text",
			"text":"格：名词在句子中和谓语是什么关系。\n表示这种关系的是格助词\nに　太多了\nで　凭借\nへ　方向\nより 比较的基准，から的正式说法\n",
			"styleAttributes":{},
			"x":-1373,
			"y":-2871,
			"width":260,
			"height":240
		},
		{
			"id":"625bc0dfee356499",
			"type":"text",
			"text":"は确定主题\n强格 中间格 弱格",
			"styleAttributes":{},
			"x":-2063,
			"y":-2811,
			"width":260,
			"height":60,
			"color":"2"
		},
		{
			"id":"98b1df288b6bd6f6",
			"type":"text",
			"text":"时间+に",
			"styleAttributes":{},
			"x":-1728,
			"y":-2811,
			"width":260,
			"height":60
		},
		{
			"id":"7ade39f768465643",
			"type":"text",
			"text":"主题信息是旧信息",
			"styleAttributes":{},
			"x":-2063,
			"y":-2531,
			"width":260,
			"height":60
		},
		{
			"id":"cb9c9524f10c484e",
			"type":"text",
			"text":"中间格 に转为へ",
			"styleAttributes":{},
			"x":-2493,
			"y":-2625,
			"width":260,
			"height":60,
			"color":"3"
		},
		{
			"id":"1ad9c99fa9d677b4",
			"type":"text",
			"text":"这里的の是格助词？",
			"styleAttributes":{},
			"x":-2493,
			"y":-2511,
			"width":260,
			"height":60,
			"color":"1"
		},
		{"id":"87e177c682365b4f","type":"file","file":"日语学习/语法系统梳理/附件/{9FEF807D-9B33-4680-B605-070427779F17}.png","x":-2173,"y":-2670,"width":478,"height":89},
		{"id":"0c87b070c3bf7ae1","type":"file","file":"日语学习/语法系统梳理/附件/{24247926-EA30-410E-BDF1-1CAD5F75C185}.png","x":-2583,"y":-2880,"width":440,"height":199},
		{
			"id":"8cc3bc1d20743093",
			"type":"text",
			"text":"表达说话者的意志，希望一起做某事",
			"styleAttributes":{},
			"x":-931,
			"y":-1496,
			"width":160,
			"height":100
		},
		{"id":"a6b16beea1b1392d","type":"file","file":"日语学习/语法系统梳理/附件/{68C24C11-D486-46B8-8C0F-0386FFB3D218}.png","x":-547,"y":-3103,"width":399,"height":87},
		{
			"id":"04c55d7b851959ca",
			"type":"text",
			"text":"ずつ 平均分配",
			"styleAttributes":{},
			"x":40,
			"y":-3480,
			"width":260,
			"height":60
		},
		{"id":"eadcea377c9fc15c","type":"file","file":"日语学习/语法系统梳理/附件/{2604DA1B-C9F2-42E2-BF7D-8EDD843A17E2}.png","x":-127,"y":-3221,"width":124,"height":220},
		{
			"id":"e5c30020cc3a4fdc",
			"type":"text",
			"text":"同样表示限定",
			"styleAttributes":{},
			"x":153,
			"y":-3301,
			"width":180,
			"height":61
		},
		{
			"id":"6506944c0cd6bc05",
			"type":"text",
			"text":"ばかり　同样表示限定",
			"styleAttributes":{},
			"x":93,
			"y":-3221,
			"width":260,
			"height":60
		},
		{
			"id":"ce2b08824e185e43",
			"type":"text",
			"text":"さえ　连和别人一起吃早餐都不行",
			"styleAttributes":{},
			"x":93,
			"y":-3141,
			"width":260,
			"height":60
		},
		{
			"id":"b13485830b29cc8d",
			"type":"text",
			"text":"こそ　强调 才",
			"styleAttributes":{},
			"x":93,
			"y":-3061,
			"width":260,
			"height":60
		},
		{
			"id":"a0333b39d4a506c4",
			"type":"text",
			"text":"すら　和さえ一致",
			"styleAttributes":{},
			"x":93,
			"y":-2981,
			"width":260,
			"height":60
		},
		{
			"id":"f4e3026e5e2e7e5f",
			"type":"text",
			"text":"でも　连……也　表示举例：……之类的／要不……",
			"styleAttributes":{},
			"x":93,
			"y":-2900,
			"width":473,
			"height":60
		},
		{
			"id":"b58f9cc460f89015",
			"type":"text",
			"text":"のみ",
			"styleAttributes":{},
			"x":-19,
			"y":-3300,
			"width":112,
			"height":60
		},
		{
			"id":"042f30239f6d740b",
			"type":"text",
			"text":"きり　就咱们俩 表示限定",
			"styleAttributes":{},
			"x":-16,
			"y":-3390,
			"width":260,
			"height":60
		},
		{
			"id":"1649739e775e494f",
			"type":"text",
			"text":"终助词",
			"styleAttributes":{},
			"x":-853,
			"y":-3090,
			"width":260,
			"height":60
		},
		{
			"id":"e80201e9b929592f",
			"type":"text",
			"text":"とも　强烈认同",
			"styleAttributes":{},
			"x":-547,
			"y":-2981,
			"width":260,
			"height":60
		},
		{
			"id":"a3936e41f3aeabec",
			"type":"text",
			"text":"もの　面对指责为自己辩解",
			"styleAttributes":{},
			"x":-547,
			"y":-2900,
			"width":317,
			"height":60
		},
