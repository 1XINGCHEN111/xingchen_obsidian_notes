			"y":-800,
			"width":260,
			"height":60
		},
		{"id":"0366bb737407ca15","type":"file","file":"日语学习/语法系统梳理/附件/{136B9598-6B31-4CAB-8190-65A9EB44DAD7}.png","x":1980,"y":-893,"width":400,"height":247},
		{
			"id":"2c1c1c0d5bc7fbc7",
			"type":"text",
			"text":"连体形：词干 + な",
			"styleAttributes":{},
			"x":-1000,
			"y":1760,
			"width":260,
			"height":60
		},
		{
			"id":"d653b0598c18577d",
			"type":"text",
			"text":"<mark style=\"background: #FFF3A3A6;\">格：名词在句子中和谓语是什么关系。\n表示这种关系的是格助词</mark>\nが　指示主语，状态对象，能力\nを    指示宾语，动作的起点，经过点、离开点\nに　太多了\nで　凭借\nへ　方向\nより 比较的基准，から的正式说法\nの　![[{487F3E6F-ED15-46BC-954A-02D6EA99C24E}.png|116]]\nや   举例子 后面可能接など",
			"styleAttributes":{},
			"x":-870,
			"y":-2700,
			"width":260,
			"height":420
		},
		{
			"id":"af3dae974be5e9a0",
			"type":"text",
			"text":"格助词",
			"styleAttributes":{},
			"x":-870,
			"y":-2205,
			"width":260,
			"height":60
		},
		{
			"id":"0e55e8b3be6d07fb",
			"type":"text",
			"text":"で只能表达中顿，に是作为副词修饰用言",
			"styleAttributes":{},
			"x":-540,
			"y":1060,
			"width":260,
			"height":60,
			"color":"2"
		},
		{"id":"e42220179bfa3c95","type":"file","file":"日语学习/语法系统梳理/附件/{BE07DBE4-664F-4C18-AB58-936122FC4CB9}.png","x":1980,"y":-560,"width":285,"height":400},
		{
			"id":"32733e30cff40635",
			"type":"text",
			"text":"副词可以直接修饰用言",
			"styleAttributes":{},
			"x":2380,
			"y":-460,
			"width":260,
			"height":60
		},
		{
			"id":"1a9bf6e56097d8ea",
			"type":"text",
			"text":"注意形容动词用と修饰的特殊情况",
			"styleAttributes":{},
			"x":2380,
			"y":-360,
			"width":260,
			"height":60
		},
		{
			"id":"e7f361042d742d56",
